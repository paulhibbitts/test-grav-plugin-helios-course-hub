{#
 # Plugin override of partials/footer.html.twig (helios theme)
 # Changes from theme original:
 #   1. git_path_prefix uses github_server plugin variable to support GitHub and Codeberg (search: PLUGIN CHANGE 1)
 #   2. Footer attribution text includes Helios Course Hub link (search: PLUGIN CHANGE 2)
 #}
<footer class="mt-16 py-8 border-t border-gray-200 dark:border-gray-700">

    {# Edit on GitHub/Codeberg link #}
        {% if theme_config.github.enabled and theme_config.github.edit_link %}
        {% set file_path = page.filePathClean %}
        {% set prefix = theme_config.github.path_prefix %}
        {% if prefix and file_path starts with prefix %}
            {% set file_path = file_path[prefix|length:] %}
        {% endif %}
        {% set git_path_prefix = (github_server == 'github.com') ? 'edit' : 'src/branch' %}{# PLUGIN CHANGE 1: github_server supports GitHub and Codeberg #}
        <div class="mb-4 border-gray-200 dark:border-gray-700 text-center">
            <a href="https://{{ github_server }}/{{ theme_config.github.repo }}/{{ git_path_prefix }}/{{ theme_config.github.branch }}/{{ file_path }}"
               target="_blank"
               rel="noopener noreferrer"
               class="edit-page-link inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-primary">
                {{ svg_icon('tabler/pencil.svg', 'w-4 h-4')|raw }}
                {{ theme_config.github.edit_text ?: 'THEME_HELIOS.EDIT_PAGE'|t }}
            </a>
        </div>
        {% endif %}

    <p class="text-center text-sm text-gray-500 dark:text-gray-400">{# PLUGIN CHANGE 2: footer attribution includes Helios Course Hub link #}Built with <a href="https://getgrav.org" target="_blank" rel="nofollow noopener noreferrer" class="hover:underline">Grav</a> · <a href="https://getgrav.org/premium/helios" target="_blank" rel="nofollow noopener noreferrer" class="hover:underline">Grav Premium Helios</a> theme · <a href="https://github.com/hibbitts-design/grav-skeleton-helios-course-hub" target="_blank" rel="nofollow noopener noreferrer" class="hover:underline">Helios Course Hub</a> by <a href="https://hibbittsdesign.org" target="_blank" rel="nofollow noopener noreferrer" class="hover:underline">hibbittsdesign.org</a></p>
</footer>
